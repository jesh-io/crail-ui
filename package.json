{
  "name": "crail-ui",
  "version": "0.2.0",
  "description": "An MCP tool UI kit in Claude's design language — primitives, chat chrome, and tool widgets that make MCP results feel native to the assistant.",
  "type": "module",
  "license": "MIT",
  "author": "Jeshurun <mail@jesh.io> (https://jesh.dev)",
  "homepage": "https://crail.jesh.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesh-io/crail-ui.git"
  },
  "bugs": "https://github.com/jesh-io/crail-ui/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ui-kit",
    "react",
    "components",
    "design-system",
    "claude",
    "chat",
    "ai"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./kit.css": "./dist/kit.css",
    "./fonts.css": "./dist/fonts.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/index.js",
    "./src/kit/index.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:site",
    "build:lib": "rm -rf dist && tsc -p tsconfig.lib.json && cp src/kit/*.css dist/",
    "build:site": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fontsource-variable/hanken-grotesk": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
